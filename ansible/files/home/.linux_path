# ~/.path
# This file is sourced by both bash and fish.
# Use standard POSIX shell syntax.

# Bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Npm
export PATH="/home/nbs/.npm-global/bin:$PATH"

# Chrome
export CHROME_EXECUTABLE="/usr/bin/google-chrome-stable"

# Goland
export GOLAND_JDK=/usr/lib/jvm/java-26-openjdk

# Local bin (includes Antigravity CLI)
export PATH="$HOME/.local/bin:$PATH"

